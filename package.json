{
  "name": "se-2",
  "version": "0.0.1",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/foundry",
      "packages/nextjs"
    ]
  },
  "scripts": {
    "deploy:foundry": "cd packages/foundry && make deploy-sepolia",
    "deploy:foundry:all": "cd packages/foundry && make deploy-all",
    "deploy:foundry:sepolia": "cd packages/foundry && make deploy-sepolia",
    "deploy:foundry:base": "cd packages/foundry && make deploy-base",
    "deploy:foundry:coredao": "cd packages/foundry && make deploy-coredao",
    "foundry:test": "cd packages/foundry && forge test -vvv",
    "foundry:clean": "cd packages/foundry && make clean",
    "foundry:info": "cd packages/foundry && make info",
    "format": "yarn next:format",
    "generate": "yarn account:generate",
    "lint": "yarn next:lint",
    "next:build": "yarn workspace @se-2/nextjs build",
    "next:check-types": "yarn workspace @se-2/nextjs check-types",
    "next:format": "yarn workspace @se-2/nextjs format",
    "next:lint": "yarn workspace @se-2/nextjs lint",
    "next:serve": "yarn workspace @se-2/nextjs serve",
    "postinstall": "husky",
    "precommit": "lint-staged",
    "start": "yarn workspace @se-2/nextjs dev",
    "test": "cd packages/foundry && forge test -vvv",
    "vercel": "yarn workspace @se-2/nextjs vercel",
    "vercel:yolo": "yarn workspace @se-2/nextjs vercel:yolo",
    "ipfs": "yarn workspace @se-2/nextjs ipfs",
    "vercel:login": "yarn workspace @se-2/nextjs vercel:login"
  },
  "packageManager": "yarn@3.2.3",
  "devDependencies": {
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10"
  },
  "engines": {
    "node": ">=20.18.3"
  }
}
